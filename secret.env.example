# Copie para secret.env e preencha. Nunca commite este arquivo.
#
# Uso:
#   ./scripts/set-github-secrets.sh setup    # primeira vez — seta tudo + gera todos os .env.local
#   ./scripts/set-github-secrets.sh refresh  # renova credenciais AWS (~4h) + todos os .env.local
#   ./scripts/set-github-secrets.sh local    # só gera os .env.local (sem GitHub)

# ── Repos GitHub ───────────────────────────────────────────────────────────────
# Não altere se estiver no mesmo org/usuário
REPO_K8S=kaikelfalcao/fiap-tech-challenge-terraform-k8s
REPO_DB=kaikelfalcao/fiap-tech-challenge-terraform-db
REPO_LAMBDA=kaikelfalcao/fiap-tech-challenge-lambda
REPO_CODEBASE=kaikelfalcao/fiap-tech-challenge-codebase

# ── Paths locais dos outros repos (relativos ao diretório k8s) ─────────────────
# Ajuste se sua estrutura de pastas for diferente
LOCAL_DB=../db
LOCAL_LAMBDA=../lambda
LOCAL_CODEBASE=../codebase

# ── AWS Lab — renove a cada ~4h (cole direto do painel AWS Academy) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ── New Relic ──────────────────────────────────────────────────────────────────
NEWRELIC_LICENSE_KEY=
NEWRELIC_ACCOUNT_ID=

# ── Aplicação ──────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=

# ── Docker Hub (para push de imagem no repo codebase) ─────────────────────────
DOCKER_USERNAME=
DOCKER_PASSWORD=
