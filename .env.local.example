# Exemplo de .env.local — credenciais locais para scripts e Terraform.
# NÃO commite este arquivo.
#
# Opção recomendada: gerar automaticamente a partir de secret.env:
#   ./scripts/set-github-secrets.sh local    # gera .env.local sem tocar no GitHub
#   ./scripts/set-github-secrets.sh refresh  # renova GitHub + .env.local de uma vez
#
# Opção manual: copie este arquivo e preencha manualmente:
#   cp .env.local.example .env.local

# ── AWS Lab (renove a cada ~4h) ────────────────────────────────────────────────
export AWS_ACCESS_KEY_ID=
export AWS_SECRET_ACCESS_KEY=
export AWS_SESSION_TOKEN=
export AWS_DEFAULT_REGION=us-east-1

# ── Secrets da aplicação ───────────────────────────────────────────────────────
export TF_VAR_newrelic_license_key=
export TF_VAR_newrelic_account_id=
export TF_VAR_newrelic_api_key=          # User API Key (NRAK-...) — New Relic > API Keys

# ── Opcional: sobrescreve o nome da Lambda se o repo lambda ainda não foi deployado
# export TF_VAR_lambda_function_name=autoflow-auth-homolog
